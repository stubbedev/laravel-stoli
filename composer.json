{
  "name": "stubbedev/laravel-stoli",
  "description": "An enhanced Laravel extension to export named routes to JavaScript, allowing you to use route names instead of URLs. Supports route grouping for modular applications. Provides type hinting for route params and responses.",
  "keywords": [
    "laravel-library",
    "routes",
    "routing"
  ],
  "type": "library",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "StubbeDev\\LaravelStoli\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "StubbeDev\\LaravelStoli\\Tests\\": "tests/"
    }
  },
  "authors": [
    {
      "name": "Alexander Stage",
      "email": "alexander.bugge.stage@gmail.com"
    }
  ],
  "require": {
    "php": "^8.2",
    "laravel/framework": "^v11.15|^12.0",
    "spatie/laravel-data": "^3|^4",
    "spatie/laravel-typescript-transformer": "^3"
  },
  "require-dev": {
    "phpunit/phpunit": "^11",
    "orchestra/testbench": "^9|^10",
    "mockery/mockery": "^1.6"
  },
  "extra": {
    "laravel": {
      "providers": [
        "StubbeDev\\LaravelStoli\\StoliServiceProvider"
      ]
    }
  }
}
